{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "description": "Group Kotlin-related updates together",
      "matchPackagePatterns": ["^org.jetbrains.kotlin"],
      "groupName": "Kotlin"
    },
    {
      "description": "Group Compose Multiplatform updates together",
      "matchPackagePatterns": ["^org.jetbrains.compose"],
      "groupName": "Compose Multiplatform"
    }
  ]
}